<!-- BreadcrumbList template — inject on every page below root. Replace URLs and names. -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://nimikh.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": "https://nimikh.com/services/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Headless Commerce",
      "item": "https://nimikh.com/services/headless-commerce/"
    }
  ]
}
</script>
