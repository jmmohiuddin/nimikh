{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/services/software", "destination": "/services/software.html" },
    { "source": "/services/marketing", "destination": "/services/marketing.html" },
    { "source": "/services/creative", "destination": "/services/creative.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/services", "destination": "/services.html" },
    { "source": "/marketplace", "destination": "/marketplace.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/case-studies", "destination": "/case-studies.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/faq", "destination": "/faq.html" }
  ]
}
